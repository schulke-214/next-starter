{
  "compilerOptions": {
    "target": "es5",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": false,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "baseUrl": "./",
    "paths": {
      "components": [
        "components"
      ],
      "functions": [
        "functions"
      ],
      "lib": [
        "lib"
      ],
      "pages": [
        "pages"
      ],
      "~": [
        "./"
      ]
    }
  },
  "exclude": [
    "./node_modules"
  ],
  "include": [
    "./config/next-env.d.ts",
    "**/*.ts",
    "**/*.tsx"
  ]
}
